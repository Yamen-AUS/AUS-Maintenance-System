  }
}

// ========================================
// INSTRUCTIONS - تعليمات الاستخدام
// ========================================

// 1. للتطوير والتجربة:
//    - استخدم القواعد في قسم "DEVELOPMENT MODE"
//    - أو استخدم "TEST MODE" مع تحديد تاريخ انتهاء
//
// 2. للإنتاج:
//    - علق قواعد DEVELOPMENT MODE
//    - افتح قواعد PRODUCTION RULES
//    - فعّل Firebase Authentication
//    - أضف Custom Claims للأدوار (Admin, Manager, Staff)
//
// 3. لنسخ هذه القواعد:
//    - افتح Firebase Console
//    - اذهب إلى Firestore Database → Rules
//    - الصق القواعد أعلاه
//    - اضغط Publish
//
// 4. اختبار القواعد:
//    - استخدم Firestore Rules Playground في Console
//    - جرّب عمليات read/write مختلفة
//    - تأكد من عمل القواعد كما هو متوقع

// ========================================
// SECURITY BEST PRACTICES
// ========================================

// ✅ استخدم Test Mode فقط للتطوير (30 يوم كحد أقصى)
// ✅ فعّل Firebase Authentication قبل الإنتاج
// ✅ استخدم Custom Claims لتحديد الأدوار
// ✅ راجع القواعد بانتظام
// ✅ استخدم Firestore Rules Playground للاختبار
// ✅ لا تضع API Keys في الكود (استخدم Environment Variables)
// ✅ فعّل App Check لمنع الاستخدام غير المصرح
// ✅ راقب الاستخدام عبر Firebase Console

// ========================================
// MONITORING
// ========================================

// راقب الاستخدام اليومي:
// - Firebase Console → Usage and billing
// - تحقق من عدد القراءات/الكتابات
// - ضع حدود (Quotas) لتجنب التكاليف المفاجئة
// - استخدم Alerts لتنبيهك عند تجاوز الحدود

// ========================================
// END OF SECURITY RULES
// ========================================
